# .env.example

# Server port
PORT=5000

# Database connection string
DATABASE_URL=

# Redis connection string
REDIS_URL=

# JWT secret for securing tokens
JWT_SECRET=

# SMTP configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Google Maps API key
GOOGLE_MAPS_API_KEY=

# Application settings
APP_NAME=
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:5000
